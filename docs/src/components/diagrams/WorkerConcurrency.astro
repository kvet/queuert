---
import Diagram from "./Diagram.astro";
---

<Diagram
  viewBox="0 0 760 540"
  alt="Worker concurrency: one worker with N slots running in parallel. A main loop fills empty slots, each slot atomically claims a different job via FOR UPDATE SKIP LOCKED."
>
  <!-- Outer worker container -->
  <g style="color: var(--d-green)">
    <rect x="30" y="30" width="700" height="330" rx="16" class="process" />
    <text x="80" y="35" text-anchor="start" class="title text-green halo">Worker (concurrency = 3)</text>

    <!-- Main loop -->
    <rect x="220" y="80" width="320" height="60" rx="10" class="worker" />
    <text x="380" y="105" class="label-strong">Main loop</text>
    <text x="380" y="125" class="muted small">fills empty slots, waits for completions</text>

    <!-- Three slots, each containing a job -->
    <g>
      <rect x="60" y="200" width="180" height="130" rx="12" class="fill-green stroke-green" />
      <text x="150" y="225" class="label-strong text-green">Slot 0</text>
      <rect x="85" y="245" width="130" height="70" rx="10" class="job-accent" />
      <text x="150" y="275" class="label-strong text-hint small">job A</text>
      <text x="150" y="295" class="muted tiny">running</text>

      <rect x="290" y="200" width="180" height="130" rx="12" class="fill-green stroke-green" />
      <text x="380" y="225" class="label-strong text-green">Slot 1</text>
      <rect x="315" y="245" width="130" height="70" rx="10" class="job-accent" />
      <text x="380" y="275" class="label-strong text-hint small">job B</text>
      <text x="380" y="295" class="muted tiny">running</text>

      <rect x="520" y="200" width="180" height="130" rx="12" class="fill-green stroke-green" />
      <text x="610" y="225" class="label-strong text-green">Slot 2</text>
      <rect x="545" y="245" width="130" height="70" rx="10" class="job-accent" />
      <text x="610" y="275" class="label-strong text-hint small">job C</text>
      <text x="610" y="295" class="muted tiny">running</text>
    </g>

    <!-- Loop → slots -->
    <path d="M 320,140 L 175,200" class="arrow s-green" marker-end="url(#d-head-green)" />
    <path d="M 380,140 L 380,200" class="arrow s-green" marker-end="url(#d-head-green)" />
    <path d="M 440,140 L 585,200" class="arrow s-green" marker-end="url(#d-head-green)" />
    <text x="170" y="173" class="halo tiny text-green">spawn / refill</text>
  </g>

  <!-- Database -->
  <g>
    <path d="M 230,420 a 150,16 0 0 1 300,0 v 70 a 150,16 0 0 1 -300,0 z" class="cylinder" />
    <ellipse cx="380" cy="420" rx="150" ry="16" class="cylinder-top" />
    <text x="380" y="458" class="label-strong text-teal">Your database</text>
    <text x="380" y="478" class="muted tiny">FOR UPDATE SKIP LOCKED</text>
    <text x="380" y="494" class="muted tiny">each slot claims a different job</text>
  </g>

  <!-- Slot ↔ DB -->
  <path d="M 150,330 C 150,375 240,395 300,407" class="arrow" marker-end="url(#d-head-stroke)" />
  <path d="M 380,330 L 380,404" class="arrow" marker-end="url(#d-head-stroke)" />
  <path d="M 610,330 C 610,375 520,395 460,407" class="arrow" marker-end="url(#d-head-stroke)" />

  <text x="380" y="385" class="halo small muted">acquire · complete</text>
</Diagram>
