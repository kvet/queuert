---
type Props = {
  viewBox: string;
  alt: string;
  maxWidth?: string;
  class?: string;
}
const { viewBox, alt, maxWidth = "780px", class: className = "" } = Astro.props;
---

<figure
  class:list={["diagram", className]}
  role="img"
  aria-label={alt}
  style={`--d-max-width: ${maxWidth}`}
>
  <svg viewBox={viewBox} xmlns="http://www.w3.org/2000/svg">
    <defs>
      {
        ["stroke", "blue", "green", "teal", "hint", "purple", "red", "gray"].map((color) => (
          <marker
            id={`d-head-${color}`}
            viewBox="0 0 10 10"
            refX="9"
            refY="5"
            markerWidth="7"
            markerHeight="7"
            orient="auto-start-reverse"
          >
            <path d="M0,0 L10,5 L0,10 z" class={`head-${color}`} />
          </marker>
        ))
      }
    </defs>
    <slot />
  </svg>
</figure>
