---
import Diagram from "./Diagram.astro";
---

<Diagram
  viewBox="0 0 760 280"
  alt="Chain identity model: the first job IS the chain — its id equals the chainId — while continuation jobs have their own ids but share the same chainId. No separate chain table."
>
  <!-- Outer chain container -->
  <g style="color: var(--d-blue)">
    <rect x="20" y="50" width="720" height="210" rx="16" class="process" stroke-dasharray="6 4" />
    <text x="60" y="55" text-anchor="start" class="title text-blue halo">chain (id = X)</text>
  </g>

  <!-- First job (accent — it IS the chain) -->
  <g>
    <rect x="60" y="80" width="180" height="140" rx="12" class="job-accent" />
    <text x="150" y="110" class="label-strong text-hint">first job</text>
    <text x="150" y="138" class="mono small">id      = X</text>
    <text x="150" y="158" class="mono small">chainId = X</text>
    <text x="150" y="198" class="caption text-hint">id === chainId</text>
  </g>

  <!-- Continuation job -->
  <g>
    <rect x="290" y="80" width="180" height="140" rx="12" class="job" />
    <text x="380" y="110" class="label-strong text-blue">continuation</text>
    <text x="380" y="138" class="mono small">id      = Y</text>
    <text x="380" y="158" class="mono small">chainId = X</text>
    <text x="380" y="198" class="caption">own id, shared chainId</text>
  </g>

  <!-- Terminal job -->
  <g>
    <rect x="520" y="80" width="180" height="140" rx="12" class="job" />
    <text x="610" y="110" class="label-strong text-blue">terminal</text>
    <text x="610" y="138" class="mono small">id      = Z</text>
    <text x="610" y="158" class="mono small">chainId = X</text>
    <text x="610" y="198" class="caption">own id, shared chainId</text>
  </g>

  <!-- Arrows -->
  <path d="M 240,150 L 290,150" class="arrow s-blue" marker-end="url(#d-head-blue)" />
  <path d="M 470,150 L 520,150" class="arrow s-blue" marker-end="url(#d-head-blue)" />
  <text x="265" y="143" class="halo tiny muted">then</text>
  <text x="495" y="143" class="halo tiny muted">then</text>
</Diagram>
