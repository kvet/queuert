---
import Diagram from "./Diagram.astro";
---

<Diagram
  viewBox="0 0 760 240"
  alt="Staged processing mode: prepare commits in a transaction, external work runs untransacted (must be idempotent) while the lease auto-renews, then complete commits in a second transaction."
>
  <!-- txn 1: prepare -->
  <rect x="40" y="30" width="200" height="90" rx="10" class="txn" />
  <text x="140" y="52" class="muted small">transaction</text>
  <rect x="60" y="70" width="160" height="40" rx="6" class="step" />
  <text x="140" y="95" class="small label-strong text-blue">prepare() — read</text>

  <!-- external work (no transaction) -->
  <rect
    x="280"
    y="30"
    width="200"
    height="90"
    rx="10"
    class="job-muted"
    stroke-dasharray="6 4"
  />
  <text x="380" y="50" class="muted tiny">no transaction</text>
  <text x="380" y="78" class="small label-strong">external work</text>
  <text x="380" y="98" class="caption text-hint">must be idempotent</text>

  <!-- lease auto-renew loop under external -->
  <path
    d="M 470,125 C 495,185 265,185 290,125"
    class="arrow dashed s-hint"
    marker-end="url(#d-head-hint)"
  />
  <text x="380" y="162" class="caption text-hint label-strong halo">
    lease auto-renews
  </text>
  <text x="380" y="178" class="caption halo">worker keeps ownership</text>

  <!-- txn 2: complete -->
  <rect x="520" y="30" width="200" height="90" rx="10" class="txn" />
  <text x="620" y="52" class="muted small">transaction</text>
  <rect x="540" y="70" width="160" height="40" rx="6" class="step" />
  <text x="620" y="95" class="small label-strong text-blue">complete() — write</text>

  <!-- Timeline -->
  <path d="M 40,210 L 720,210" class="arrow" marker-end="url(#d-head-stroke)" />
  <text x="140" y="228" class="caption">claim</text>
  <text x="380" y="228" class="caption">external call</text>
  <text x="620" y="228" class="caption">results written</text>
</Diagram>
