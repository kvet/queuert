{
  "name": "@queuert/postgres",
  "version": "0.14.0",
  "description": "PostgreSQL state and notify adapter for Queuert",
  "keywords": [
    "background-jobs",
    "job-queue",
    "postgresql",
    "queue",
    "task-queue",
    "transactional",
    "transactional-outbox-pattern",
    "typescript",
    "workflow",
    "workflow-engine"
  ],
  "homepage": "https://kvet.github.io/queuert/",
  "bugs": {
    "url": "https://github.com/kvet/queuert/issues"
  },
  "license": "MIT",
  "author": "kvet",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kvet/queuert.git"
  },
  "files": [
    "dist",
    "!dist/testing*",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./testing": "./dist/testing.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "prepublishOnly": "bun run build",
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "test": "vitest --run"
  },
  "devDependencies": {
    "@queuert/testcontainers": "workspace:*",
    "@queuert/tsconfig": "workspace:*",
    "@queuert/typed-sql": "workspace:*",
    "@types/pg": "8.20.0",
    "pg": "8.20.0",
    "postgres": "3.4.9",
    "queuert": "workspace:*"
  },
  "peerDependencies": {
    "queuert": "workspace:*"
  },
  "engines": {
    "node": ">=22"
  },
  "x-examples": "https://github.com/kvet/queuert/tree/main/examples",
  "x-llms-txt": "https://kvet.github.io/queuert/llms-full.txt"
}
