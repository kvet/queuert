{
  "name": "example-dashboard",
  "version": "0.0.1",
  "private": true,
  "description": "An example demonstrating the @queuert/dashboard web UI with SQLite.",
  "license": "MIT",
  "author": "kvet",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kvet/queuert.git"
  },
  "type": "module",
  "scripts": {
