{
  "name": "benchmark-processing-capacity",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --import=tsx src/index.ts",
    "start:state-postgres-postgres-js": "node --import=tsx src/index.ts --state-postgres-postgres-js",
    "start:state-postgres-pg": "node --import=tsx src/index.ts --state-postgres-pg",
    "start:state-sqlite-better-sqlite3": "node --import=tsx src/index.ts --state-sqlite-better-sqlite3",
    "start:state-sqlite-node": "node --import=tsx src/index.ts --state-sqlite-node",
    "start:state-in-process": "node --import=tsx src/index.ts --state-in-process",
    "start:notify-redis-redis": "node --import=tsx src/index.ts --notify-redis-redis",
    "start:notify-redis-ioredis": "node --import=tsx src/index.ts --notify-redis-ioredis",
    "start:notify-postgres-pg": "node --import=tsx src/index.ts --notify-postgres-pg",
    "start:notify-postgres-postgres-js": "node --import=tsx src/index.ts --notify-postgres-postgres-js",
    "start:notify-nats-nats": "node --import=tsx src/index.ts --notify-nats-nats",
    "start:notify-in-process": "node --import=tsx src/index.ts --notify-in-process",
    "typecheck": "! tsgo --noEmit 2>&1 | grep -v 'TS4023' | grep 'error TS'"
  },
  "dependencies": {
    "@queuert/nats": "workspace:*",
    "@queuert/postgres": "workspace:*",
    "@queuert/redis": "workspace:*",
    "@queuert/sqlite": "workspace:*",
    "better-sqlite3": "12.9.0",
    "example-notify-postgres-pg": "workspace:*",
    "example-notify-postgres-postgres-js": "workspace:*",
    "example-notify-redis-ioredis": "workspace:*",
    "example-notify-redis-redis": "workspace:*",
    "example-state-postgres-pg": "workspace:*",
    "example-state-postgres-postgres-js": "workspace:*",
    "example-state-sqlite-better-sqlite3": "workspace:*",
    "example-state-sqlite-node": "workspace:*",
    "ioredis": "5.10.1",
    "nats": "2.29.3",
    "pg": "8.20.0",
    "postgres": "3.4.9",
    "queuert": "workspace:*",
    "redis": "5.11.0"
  },
  "devDependencies": {
    "@queuert/tsconfig": "workspace:*",
    "@testcontainers/nats": "11.14.0",
    "@testcontainers/postgresql": "11.14.0",
    "@testcontainers/redis": "11.14.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/pg": "8.20.0"
  }
}
