{
  "name": "benchmark-memory-footprint",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --expose-gc --import=tsx src/index.ts --all",
    "start:state-postgres": "node --expose-gc --import=tsx src/index.ts --state-postgres",
    "start:state-sqlite": "node --expose-gc --import=tsx src/index.ts --state-sqlite",
    "start:notify-redis": "node --expose-gc --import=tsx src/index.ts --notify-redis",
    "start:notify-postgres": "node --expose-gc --import=tsx src/index.ts --notify-postgres",
    "start:notify-nats": "node --expose-gc --import=tsx src/index.ts --notify-nats",
    "start:otel": "node --expose-gc --import=tsx src/index.ts --otel",
    "start:dashboard": "node --expose-gc --import=tsx src/index.ts --dashboard",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/sdk-metrics": "2.6.1",
    "@queuert/dashboard": "workspace:*",
    "@queuert/nats": "workspace:*",
    "@queuert/otel": "workspace:*",
    "@queuert/postgres": "workspace:*",
    "@queuert/redis": "workspace:*",
    "@queuert/sqlite": "workspace:*",
    "better-sqlite3": "12.9.0",
    "example-notify-postgres-postgres-js": "workspace:*",
    "example-notify-redis-redis": "workspace:*",
    "example-state-postgres-postgres-js": "workspace:*",
    "example-state-sqlite-better-sqlite3": "workspace:*",
    "nats": "2.29.3",
    "pg": "8.20.0",
    "postgres": "3.4.9",
    "queuert": "workspace:*",
    "redis": "5.11.0"
  },
  "devDependencies": {
    "@queuert/tsconfig": "workspace:*",
    "@testcontainers/nats": "11.14.0",
    "@testcontainers/postgresql": "11.14.0",
    "@testcontainers/redis": "11.14.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/pg": "8.20.0"
  }
}
