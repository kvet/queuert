{
  "name": "queuert-monorepo",
  "private": true,
  "keywords": [],
  "license": "MIT",
  "author": "kvet",
  "workspaces": [
    "benchmarks/*",
    "docs",
    "examples/*",
    "packages-internal/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "lint": "oxlint --type-aware",
    "fmt": "oxlint --type-aware --fix && oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "vitest --run",
    "typecheck": "bun run --filter '*' typecheck",
    "benchmarks": "bun run --filter benchmark-memory-footprint start && bun run --filter benchmark-processing-capacity start && bun run --filter benchmark-type-complexity start",
    "examples": "bun run --filter './examples/*' start",
    "check": "bun run fmt:check && bun run lint && bun run typecheck && bun run build && vitest --run && bun run examples",
    "modules:clean": "rm -rf $(find . -name node_modules -type d)",
    "changeset": "changeset",
    "version": "changeset version",
    "docs:dev": "bun run --filter @queuert/docs dev",
    "docs:build": "bun run --filter @queuert/docs build",
    "docs:preview": "bun run --filter @queuert/docs preview"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@types/node": "22.19.15",
    "@typescript/native-preview": "7.0.0-dev.20260413.1",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.18.1",
    "tsdown": "0.21.7",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=22"
  }
}
