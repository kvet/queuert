{
  "name": "queuert-monorepo",
  "private": true,
  "keywords": [],
  "license": "MIT",
  "author": "kvet",
  "scripts": {
    "build": "turbo build",
    "lint": "oxlint --type-aware",
    "fmt": "oxlint --type-aware --fix && oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "vitest --run",
    "typecheck": "turbo typecheck",
    "benchmarks": "turbo start --filter=\"./benchmarks/*\" --concurrency=1",
    "examples": "turbo start --filter=\"./examples/*\"",
    "check": "pnpm fmt:check && pnpm lint && pnpm typecheck && pnpm build && vitest --run && pnpm examples",
    "modules:clean": "rm -rf $(find . -name node_modules -type d)",
    "changeset": "changeset",
    "version": "changeset version",
    "docs:dev": "pnpm --filter @queuert/docs dev",
    "docs:build": "pnpm --filter @queuert/docs build",
    "docs:preview": "pnpm --filter @queuert/docs preview",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@typescript/native-preview": "7.0.0-dev.20260222.1",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.47.0",
    "oxlint-tsgolint": "^0.12.2",
    "tsdown": "^0.20.3",
    "turbo": "^2.8.14",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.17.0"
}
