{
  "name": "queuert-monorepo",
  "private": true,
  "keywords": [],
  "license": "MIT",
  "author": "kvet",
  "workspaces": [
    "benchmarks/*",
    "docs",
    "examples/*",
    "packages-internal/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "lint": "oxlint --type-aware",
    "fmt": "oxlint --type-aware --fix && oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "vitest --run && bun run test:bun",
    "test:ci": "vitest --run --retry=2 --maxWorkers=$(($(nproc) - 2)) && bun run test:bun",
    "test:bun": "bun run --filter example-state-sqlite-bun test",
    "typecheck": "bun run --filter '*' typecheck",
    "benchmarks": "bun run --filter './benchmarks/*' --sequential start",
    "examples": "bun run --filter './examples/*' start",
    "check": "bun run fmt:check && bun run typecheck && bun run build && bun run test && bun run examples",
    "modules:clean": "rm -rf $(find . -name node_modules -type d)",
    "changeset": "changeset",
    "version": "changeset version",
    "docs:dev": "bun run --filter @queuert/docs dev",
    "docs:build": "bun run --filter @queuert/docs build",
    "docs:preview": "bun run --filter @queuert/docs preview"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@types/node": "22.19.15",
    "@typescript/native-preview": "7.0.0-dev.20260413.1",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.20.0",
    "tsdown": "0.21.8",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=22"
  }
}
